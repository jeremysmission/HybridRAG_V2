  "note": "Deterministic row-level lookups against the staged Lane 2 follow-on entity store. Measured via src.store.entity_store.EntityStore.query_tables — NOT via the LLM query pipeline. This slice proves row data is retrievable and addressable at the substrate layer. It does NOT claim retrieval/routing/aggregation improvement on the 400-pack. The 400-pack is frozen; do not edit it.",
  "queries": [
    {
      "id": "T-01",
      "family": "received_po",
      "kind": "exact_po_lookup",
      "question_plain": "Find the row for PO Number 5300045239.",
      "query_tables": {"value_contains": "5300045239"},
      "expect_min_rows": 1,
      "expect_any_header": ["PO Number"],
      "expect_any_source_contains": ["PR & PO"]
    },
    {
      "id": "T-02",
      "family": "spares_report",
      "kind": "exact_part_lookup",
      "question_plain": "Find the spares row for Part Number ZFBT-4R2G-FT+.",
      "query_tables": {"value_contains": "ZFBT-4R2G-FT+"},
      "expect_min_rows": 1,
      "expect_any_header": ["Part Number"],
      "expect_any_source_contains": ["Spares"]
    },
    {
      "id": "T-03",
      "family": "spares_report",
      "kind": "description_lookup",
      "question_plain": "Find the spares row for a Power Supply, Redundant, 900W.",
      "query_tables": {"value_contains": "Power Supply, Redundant, 900W"},
      "expect_min_rows": 1,
      "expect_any_header": ["Part Description"],
      "expect_any_source_contains": ["Spares"]
    },
    {
      "id": "T-04",
      "family": "received_po",
      "kind": "header_enumeration",
