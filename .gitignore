# Agent instruction files — never push to remote
CLAUDE.md
CoPilot+.md

# Production/simulation data — never commit
ProductionSource/

# Zip archives, screenshots, images — never push
*.zip
*.jpg
*.jpeg
*.png
*.gif
*.bmp

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environment
.venv/
venv/
env/

# Offline install bundles (wheels + HF model snapshots) — build artifacts, too large to commit
vendor/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Machine-specific config overrides (workers, GPU, paths)
config/config.local.yaml

# Data (large files - do not commit)
data/
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal
*.faiss
*.f16.dat
*.lance/

# Sanitization script — NEVER push to remote (contains replacement patterns)
sanitize_before_push.py

# Credentials / secrets
.env
*.key
*.pem
credentials.json
secrets.yaml

# Logs
logs/
*.log

# Test output
.pytest_cache/
htmlcov/
.coverage

# Docx build artifacts (keep the docx files themselves)
# *.docx  -- we DO want these committed

# Installer binaries — never commit
*.exe
*.msi

# Diagnostic screenshots — archive locally, do not commit
EnvVar_*.jpg
EnvVar_*.png
installFail.jpg
oss.jpg
tokencost.jpg
Wrong_PythonVersion_*.png

# Benchmark result JSONs (keep golden eval results in tests/)
benchmark_results_*.json

# Ad-hoc results folder at repo root
/results/

# Eval GUI per-operator persisted defaults (live runtime state, not shared)
/.eval_gui_defaults.json

# Local-only agentic references, private manifests, and dev-only notes
/LOCAL_ONLY/

