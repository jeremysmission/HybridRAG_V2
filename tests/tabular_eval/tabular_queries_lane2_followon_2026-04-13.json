      "query_tables": {"value_contains": "0031393862"},
      "expect_min_rows": 1,
      "expect_any_header": ["PR Number"],
      "expect_any_source_contains": ["PR & PO"]
    },
    {
      "id": "T-07",
      "family": "spares_report",
      "kind": "pipe_joined_row_lookup",
